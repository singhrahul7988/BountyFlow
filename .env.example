NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Fallback if your dashboard shows "anon key" instead of "publishable key"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_EVIDENCE_BUCKET=submission-evidence
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_RPC_URL=https://your-evm-rpc-url
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated emails that are allowed to sign up as project owners/admins.
OWNER_ALLOWED_EMAILS=owner@example.com
# Keep this as "mock" for the hackathon demo. Real WDK / chain settlement is not wired yet.
BOUNTYFLOW_ONCHAIN_MODE=mock
WDK_CHAIN_ID=11155111
WDK_RPC_URL=https://your-evm-rpc-url
WDK_TREASURY_SEED_PHRASE="your twelve word seed phrase"
WDK_TREASURY_ACCOUNT_INDEX=0
WDK_USDT_TOKEN_ADDRESS=0xYourUsdtTokenContract
WDK_USDT_DECIMALS=6
WDK_TRANSFER_MAX_FEE_WEI=500000000000000
WDK_AAVE_ENABLED=false
# Legacy fallback only if you still need the allowlist in the browser.
# NEXT_PUBLIC_OWNER_ALLOWED_EMAILS=owner@example.com

# Google AI Studio / Gemini
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash
